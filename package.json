  "files": [
    "dist",
    "src/data",
    "README.md",
    "LICENSE",
    "docs",
    "examples"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json && npm run copy-assets",
    "copy-assets": "cpx \"src/**/*.{json,md}\" dist/src",
    "dev": "tsx ./src/cli/index.ts",
    "start": "node ./dist/src/cli/index.js",
    "test": "tsx ./tests/group-01.test.ts && tsx ./tests/group-02-technical-seo.test.ts && tsx ./tests/group-03-performance-seo.test.ts && tsx ./tests/group-04-on-page-seo.test.ts && tsx ./tests/group-05-keyword-research-intent.test.ts && tsx ./tests/group-06-content-strategy-planning.test.ts && tsx ./tests/group-07-site-architecture-internal-linking.test.ts && tsx ./tests/group-08-schema-entity-seo.test.ts && tsx ./tests/group-09-media-seo.test.ts && tsx ./tests/group-10-ecommerce-seo.test.ts && tsx ./tests/group-11-local-international-seo.test.ts && tsx ./tests/group-12-ai-search-discover-seo.test.ts && tsx ./tests/group-13-trust-security-accessibility.test.ts && tsx ./tests/group-14-cms-framework-seo.test.ts && tsx ./tests/group-15-website-audit.test.ts && tsx ./tests/group-16-competitor-analysis.test.ts && tsx ./tests/group-17-seo-strategy-campaign-planning.test.ts && tsx ./tests/group-18-measurement-reporting-governance.test.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "mcp": "node ./dist/src/mcp/server.js",
    "prepublishOnly": "npm run build && npm test"
  },
  "keywords": [
    "seo",
    "mcp",
    "ai-skill",
    "openai",
    "claude",
    "cursor",
    "windsurf",
    "continue"
