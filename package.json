{
  "name": "master-of-seo",
  "version": "0.1.0",
  "description": "An npm-ready, MCP-compatible AI skill for gated SEO orchestration with /seo-master.",
  "type": "module",
  "main": "./dist/src/core/orchestrator.js",
  "bin": {
    "seo-master": "./dist/src/cli/index.js",
    "master-of-seo": "./dist/src/cli/index.js"
  },
  "exports": {
    ".": "./dist/src/core/orchestrator.js",
    "./orchestrator": "./dist/src/core/orchestrator.js",
    "./mcp": "./dist/src/mcp/server.js",
    "./command-registry": "./dist/src/core/command-registry.js",
    "./memory": "./dist/src/core/memory.js",
    "./technical-audit": "./dist/src/technical/technical-audit.js",
    "./performance-audit": "./dist/src/performance/performance-audit.js",
    "./on-page-audit": "./dist/src/on-page/on-page-audit.js",
    "./keyword-research": "./dist/src/keywords/keyword-research.js",
    "./content-plan": "./dist/src/content/content-plan.js",
    "./architecture-audit": "./dist/src/architecture/architecture-audit.js",
    "./schema-audit": "./dist/src/schema/schema-audit.js",
    "./schema-generate": "./dist/src/schema/schema-generate.js"
  },
  "files": [
    "README.md",
    "LICENSE",
    "dist",
    "src",
    "memory",
    "prompts"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "node ./src/cli/index.ts",
    "start": "node ./dist/src/cli/index.js",
    "test": "node ./tests/group-01.test.ts && node ./tests/group-02-technical-seo.test.ts && node ./tests/group-03-performance-seo.test.ts && node ./tests/group-04-on-page-seo.test.ts && node ./tests/group-05-keyword-research-intent.test.ts && node ./tests/group-06-content-strategy-planning.test.ts && node ./tests/group-07-site-architecture-internal-linking.test.ts && node ./tests/group-08-schema-entity-seo.test.ts",
    "mcp": "node ./src/mcp/server.ts",
    "prepublishOnly": "npm run build && npm test"
  },
  "keywords": [
    "seo",
    "mcp",
    "ai-skill",
    "openai",
    "claude",
    "cursor",
    "windsurf",
    "continue"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "typescript": "^5.7.0"
  }
}
