    "./on-page-audit": "./dist/src/on-page/on-page-audit.js",
    "./keyword-research": "./dist/src/keywords/keyword-research.js",
    "./content-plan": "./dist/src/content/content-plan.js",
    "./architecture-audit": "./dist/src/architecture/architecture-audit.js",
