    "./media-audit": "./dist/src/media/media-audit.js",
    "./ecommerce-audit": "./dist/src/ecommerce/ecommerce-audit.js",
    "./local-seo-audit": "./dist/src/local-international/local-seo-audit.js",
    "./international-seo-audit": "./dist/src/local-international/international-seo-audit.js",
    "./ai-search-audit": "./dist/src/ai-discover/ai-search-audit.js",
    "./discover-seo-audit": "./dist/src/ai-discover/discover-seo-audit.js",
    "./trust-audit": "./dist/src/trust-security-accessibility/trust-audit.js",
    "./security-audit": "./dist/src/trust-security-accessibility/security-audit.js",
    "./accessibility-audit": "./dist/src/trust-security-accessibility/accessibility-audit.js",
    "./framework-seo-audit": "./dist/src/cms-framework/framework-seo-audit.js",
    "./website-audit": "./dist/src/website-audit/website-audit.js",
    "./page-audit": "./dist/src/website-audit/page-audit.js",
    "./competitor-analysis": "./dist/src/competitors/competitor-analysis.js",
    "./seo-strategy": "./dist/src/strategy/seo-strategy.js",
    "./seo-plan": "./dist/src/strategy/seo-plan.js",
