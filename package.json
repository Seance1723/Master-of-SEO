  "author": "Master of SEO contributors",
  "license": "MIT",
  "homepage": "https://github.com/Seance1723/Master-of-SEO#readme",
  "bugs": {
    "url": "https://github.com/Seance1723/Master-of-SEO/issues"
  },
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "cpx": "^1.5.0",
    "tsx": "^4.22.3",
    "typescript": "^5.7.0"
  }
